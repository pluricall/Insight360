generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL_POSTGRES")
}

model GalpInboundSchema {
  id                String @id @default(uuid())
  call_uuid         String
  call_start        DateTime
  owner_name        String
  call_end          DateTime
  talk_time         Int?
  servicos_assistencia String?
  queue_time        Int
  wait_time         Int
  term_reason       String
  call_outcome_group String
  call_outcome_name String
  createdAt         DateTime @default(now())
}

model GalpOutboundSchema {
  id                   String  @id @default(uuid())
  call_uuid            String
  call_outcome_group   String
  servicos_assistencia String?
  call_start          DateTime
  createdAt           DateTime @default(now())
}
